generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(VOLUNTEER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  scans     Scan[]
}

model Player {
  id           String        @id @default(cuid())
  qrToken      String?       @unique
  playerNumber String        @unique
  name         String?
  photoUrl     String?
  photoLocked  Boolean       @default(false)
  isRegistered Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  rounds       RoundStatus[]
  scans        Scan[]
  teamLogin    TeamLogin?
}

model RoundStatus {
  id        String      @id @default(cuid())
  playerId  String
  round     RoundName
  status    RoundResult @default(PENDING)
  updatedAt DateTime    @updatedAt
  updatedBy String?
  player    Player      @relation(fields: [playerId], references: [id])

  @@unique([playerId, round])
}

model Scan {
  id          String   @id @default(cuid())
  playerId    String
  volunteerId String
  scannedAt   DateTime @default(now())
  player      Player   @relation(fields: [playerId], references: [id])
  volunteer   User     @relation(fields: [volunteerId], references: [id])
}

model TeamLogin {
  id       String @id @default(cuid())
  playerId String @unique
  pin      String
  player   Player @relation(fields: [playerId], references: [id])
}

model ProtocolToken {
  id        String   @id @default(cuid())
  token     String   @unique
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  VOLUNTEER
}

enum RoundName {
  PRELIMINARY
  RED_LIGHT_GREEN_LIGHT
  HITCH_HIKE
  SOUL_SEEKERS
  GLASS_BRIDGE
  THE_WRIGHT_WAY
  CHOCOLATE_CRUCIBLE
}

enum RoundResult {
  PENDING
  SURVIVED
  ELIMINATED
}
